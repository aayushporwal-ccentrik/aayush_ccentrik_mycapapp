{
  "scopes": [
    {
      "name": "$XSAPPNAME.Viewer",
      "description": "Viewer"
    },
    {
      "name": "$XSAPPNAME.Editor",
      "description": "Editor"
    }
  ],
  "attributes": [
    {
      "name": "BankName",
      "description": "BankName",
      "valueType": "s",
      "valueRequired": false
    },
    {
      "name": "Country",
      "description": "Country",
      "valueType": "s",
      "valueRequired": false
    }
  ],
  "role-templates": [
    {
      "name": "Viewer",
      "description": "View all the data",
      "scope-references": [
        "$XSAPPNAME.Viewer"
      ],
      "attribute-references": [
        "BankName",
        "Country"
      ]
    },
    {
      "name": "Editor",
      "description": "Edit the data",
      "scope-references": [
        "$XSAPPNAME.Editor"
      ],
      "attribute-references": []
    }
  ],

  "oauth2-configuration": {
    "redirect-uris": [
        "https://*.cfapps.us10-001.hana.ondemand.com/**"
    ]
}
}
