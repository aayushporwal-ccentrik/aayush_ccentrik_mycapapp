{
    "welcomeFile": "/index.html",
    "authenticationMethod": "route",
    "sessionTimeout": 100,
    "routes": [
    {
         "source":  "^/(.*\\.html|.*\\.js|.*\\.css|.*\\.json|.*\\.png|.*\\.ico)$",
         "localDir": "webapp",
         "authenticationType": "xsuaa"
    },
    
    {
        "source": "^/(.*)$", 
        "destination": "srv-api",
        "authenticationType": "xsuaa"
    }
    ]


}
