{
  "name": "cap_app",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/approuter": "^21.3.0",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-managepo": "cds watch --open com.aayush.procurement.po.managepo/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db.sqlite"
        },
        "[production]": {
          "kind": "hana"
        }
      },
      "auth": {
        "kind": "mocked",
        "[production]": {
          "strategy": "JWT"
        },
        "[development]": {
          "strategy": "mocked",
          "users": {
            "aayush": {
              "roles": [
                "Viewer"
              ],
              "userAttributes": {
                "BankName": [
                  "SBI"
                ],
                "Country": [
                  "$UNRESTRICTED"
                ]
              }
            }
          },
          "anubhav": {}
        }
      },
      "[production]": {
        "auth": {
          "kind": "mocked"
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/managepo",
    "app/managepo"
  ]
}
